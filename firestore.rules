rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isPrincipal() {
      return isSignedIn() && userRole() == 'Principal';
    }

    function isTeacherOrPrincipal() {
      return isSignedIn() && userRole() in ['Teacher', 'Principal'];
    }

    // ── Users ────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isPrincipal();
      allow delete: if isPrincipal();

      // Notifications sub-collection
      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        allow create: if isSignedIn();
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    // ── Students (record-only, no auth) ─────────────────────────────
    match /students/{studentId} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrPrincipal();
      allow update: if isTeacherOrPrincipal();
      allow delete: if isPrincipal();
    }

    // ── Classes ──────────────────────────────────────────────────────
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrPrincipal();
      allow update: if isSignedIn();
      allow delete: if isPrincipal();
    }

    // ── Grades ───────────────────────────────────────────────────────
    match /grades/{gradeId} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrPrincipal();
      allow update: if isTeacherOrPrincipal();
      allow delete: if isPrincipal();
    }

    // ── Announcements ────────────────────────────────────────────────
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrPrincipal();
      allow update: if isTeacherOrPrincipal();
      allow delete: if isPrincipal();
    }

    // ── Votes ────────────────────────────────────────────────────────
    match /votes/{voteId} {
      allow read: if isSignedIn();
      allow create: if isPrincipal();
      allow update: if isSignedIn();
      allow delete: if isPrincipal();
    }

    // ── Homework ─────────────────────────────────────────────────────
    match /homework/{homeworkId} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrPrincipal();
      allow update: if isSignedIn();
      allow delete: if isTeacherOrPrincipal();
    }

    // ── Messages (1:1) ──────────────────────────────────────────────
    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    // ── Behavior Points ─────────────────────────────────────────────
    match /behavior_points/{pointId} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrPrincipal();
      allow update: if false;
      allow delete: if isTeacherOrPrincipal();
    }

    // ── Attendance ──────────────────────────────────────────────────
    match /attendance/{recordId} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrPrincipal();
      allow update: if isTeacherOrPrincipal();
      allow delete: if isPrincipal();
    }

    // ── Stories (Class Story / Photo Sharing) ───────────────────────
    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isTeacherOrPrincipal();
    }

    // ── Activity Feed ───────────────────────────────────────────────
    match /activities/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isPrincipal();
    }

    // ── Group Conversations ─────────────────────────────────────────
    match /group_conversations/{groupId} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrPrincipal();
      allow update: if isSignedIn();
      allow delete: if isPrincipal();

      match /messages/{msgId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if false;
        allow delete: if false;
      }
    }

    // ── Beyond School Content ───────────────────────────────────────
    match /content/{itemId} {
      allow read: if isSignedIn();
      allow create: if isPrincipal();
      allow update: if isSignedIn();
      allow delete: if isPrincipal();
    }
  }
}
