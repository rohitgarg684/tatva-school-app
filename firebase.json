{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "tatva-school-app",
          "appId": "1:859841471446:android:6feb3a04db6c74b9a63a77",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "tatva-school-app",
          "configurations": {
            "android": "1:859841471446:android:6feb3a04db6c74b9a63a77",
            "ios": "1:859841471446:ios:83e51016c097dfbba63a77",
            "macos": "1:859841471446:ios:83e51016c097dfbba63a77",
            "web": "1:859841471446:web:53ea03aa5a1d7d74a63a77"
          }
        }
      }
    }
  }
}
